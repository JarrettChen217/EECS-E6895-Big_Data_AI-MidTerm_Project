# Optional: use only one GPU (e.g. 0) when multiple are available
# CUDA_VISIBLE_DEVICES=0

# LLM backend: huggingface | openai
LLM_BACKEND=huggingface

# Hugging Face (required when LLM_BACKEND=huggingface)
HF_TOKEN=your_huggingface_token_here

# Model name for Hugging Face (e.g. Qwen/Qwen2.5-3B-Instruct)
HF_MODEL_NAME=Qwen/Qwen2.5-3B-Instruct

# OpenAI (required when LLM_BACKEND=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# RAG corpus path (JSONL with doc_id, text per line)
CORPUS_PATH=data/corpus/ad_policy_corpus.jsonl

# Embedding model for RAG
EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# RAG top-k retrieval
RAG_TOP_K=3
