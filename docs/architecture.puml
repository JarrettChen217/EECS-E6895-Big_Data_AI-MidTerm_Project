@startuml

title Marketing Agent Architecture - UML

package "marketing_agent" {

  [config]

  package "LLM" {
    [BaseLLM]
    [HuggingFaceLLM]
    [OpenAILLM]
    [get_llm()]
  }

  package "RAG" {
    [Corpus / VectorStore / Retriever]
    [rag_answer()]
  }

  package "Tools" {
    [platform_chooser]
    [rag_tool]
  }

  package "Agent" {
    [route_question]
    [run_agent]
    [synthesize_answer]
  }

  [chat]
}

[chat] --> [get_llm()]
[chat] --> [BaseLLM]

[run_agent] --> [route_question]
[run_agent] --> [synthesize_answer]
[run_agent] --> [get_llm()]
[run_agent] --> [rag_answer()]
[run_agent] --> [platform_chooser]
[run_agent] --> [rag_tool]

[rag_answer()] --> [Corpus / VectorStore / Retriever]

[HuggingFaceLLM] --> [config]
[OpenAILLM] --> [config]
[run_agent] --> [config]

@enduml